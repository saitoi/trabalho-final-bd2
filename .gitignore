# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.env

# Raw datasets: keep only the directory placeholder in git.
data/raw/**
!data/raw/
!data/raw/.gitkeep

# Generated processed datasets and local editor swap files.
data/processed/**
!data/processed/
!data/processed/.gitkeep
data/samples/**
!data/samples/
!data/samples/.gitkeep
*.swp
