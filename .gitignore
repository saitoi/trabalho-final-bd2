# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.env
.pytest_cache/
.uv-cache/

# Raw datasets: keep only the directory placeholder in git.
data/raw/**
!data/raw/
!data/raw/.gitkeep

# Generated processed datasets and local editor swap files.
data/processed/**
!data/processed/
!data/processed/.gitkeep
data/samples/**
!data/samples/
!data/samples/.gitkeep
*.swp

# Node.js dependencies — always install locally, never commit.
node_modules/
frontend/.npm-cache/

# Documentation: keep folder structure, ignore contents.
docs/**
!docs/
!docs/.gitkeep
