# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.env
.pytest_cache/
.uv-cache/

# Raw datasets: keep only the directory placeholder in git.
dataset/raw/**
!dataset/raw/
!dataset/raw/.gitkeep

# Generated processed datasets and local editor swap files.
dataset/processed/**
!dataset/processed/
!dataset/processed/.gitkeep
dataset/samples/**
!dataset/samples/
!dataset/samples/.gitkeep
*.swp

# Node.js dependencies — always install locally, never commit.
node_modules/
frontend/.npm-cache/

# Documentation: keep folder structure, ignore contents.
docs/**
!docs/
!docs/.gitkeep
